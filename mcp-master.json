{
  "mcpServers": {
    "filesystem": {
      "command": "/workspace/CIPHER-MCP/.mcp_env/node/node_modules/.bin/server-filesystem",
      "args": [
        "/absolute/path/to/your/workspace"
      ]
    },
    "github": {
      "command": "/workspace/CIPHER-MCP/.mcp_env/node/node_modules/.bin/server-github",
      "args": [],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_ENTERPRISE_TOKEN}"
      }
    },
    "tavily-search": {
      "command": "/workspace/CIPHER-MCP/.mcp_env/node/node_modules/.bin/tavily-mcp",
      "args": [],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "mem0-memory": {
      "command": "/workspace/CIPHER-MCP/.mcp_env/node/node_modules/.bin/mcp-server",
      "args": [],
      "env": {
        "MEM0_API_KEY": "${MEM0_API_KEY}"
      }
    },
    "google-ai-studio": {
      "command": "/workspace/CIPHER-MCP/.mcp_env/node/node_modules/.bin/mcp-server-google-generative-ai",
      "args": [],
      "env": {
        "GOOGLE_AI_STUDIO_API_KEY": "${GOOGLE_AI_STUDIO_API_KEY}"
      }
    },
    "sqlite-audit-db": {
      "command": "/workspace/CIPHER-MCP/.mcp_env/python/bin/mcp-server-sqlite",
      "args": [
        "--db-path",
        "/absolute/path/to/your/audit_store.db"
      ]
    }
  }
}
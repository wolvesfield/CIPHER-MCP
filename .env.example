# =============================================================================
# CIPHER-MCP  –  THE GOVERNMENT — Enterprise Secrets Template
# Copy to .env and fill in real values.  NEVER commit .env to source control.
# =============================================================================

# --- GITHUB ENTERPRISE CLOUD (GHEC) -----------------------------------------
# Fine-Grained PAT authorised for the Enterprise SSO tenant.
# Required scopes: repo, read:org, read:enterprise
# Enterprise dashboard : https://github.com/enterprises/nochef
# Organisation URL     : https://github.com/organizations/wolvesfield
GITHUB_ENTERPRISE_TOKEN=github_pat_REPLACE_ME

# For GHEC Cloud the REST base URL stays standard.
# Override only for GHES (self-hosted) deployments.
GITHUB_API_URL=https://api.github.com

# Slug of your enterprise organisation (used by github-enterprise-cloud server)
GITHUB_ORG_NAME=wolvesfield

# --- DATABASE ----------------------------------------------------------------
# Supabase Management API personal access token (sbp_… prefix)
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_REPLACE_ME

# --- AI / SEARCH SERVICES ----------------------------------------------------
TAVILY_API_KEY=tvly-REPLACE_ME
MEM0_API_KEY=m0-REPLACE_ME
GOOGLE_AI_STUDIO_API_KEY=REPLACE_ME

# --- INFRA / HOSTING ----------------------------------------------------------
HOSTINGER_API_TOKEN=REPLACE_ME
ANTIGRAVITY_PORT=9222
GOOGLE_CLOUD_CREDS_PATH=/absolute/path/to/gcp-service-account.json

# --- BLOCKCHAIN --------------------------------------------------------------
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# =============================================================================
# THE GOVERNMENT — 4-General Autonomous Army
# =============================================================================

# --- VICE PRESIDENT (Consensus Arbiter) — DeepSeek V3.2 --------------------
DEEPSEEK_API_KEY=REPLACE_ME
EARLY_TERM_THRESHOLD=0.85
MIN_CONFIDENCE=0.30
QUARANTINE_THRESHOLD=5

# --- BROSKI COMMS (Telegram) ------------------------------------------------
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# --- GENERAL ALPHA — The Scout (Gemini 3 Pro) :8010 -------------------------
GEMINI_API_KEY=REPLACE_ME
GENERAL_ALPHA_URL=http://general-alpha:8010

# --- GENERAL BRAVO — The Builder (GPT-5.3-Codex) :8011 ----------------------
OPENAI_API_KEY=sk-REPLACE_ME
GENERAL_BRAVO_URL=http://general-bravo:8011

# --- GENERAL CHARLIE — The Guardian (Claude Opus 4.6) :8012 -----------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GENERAL_CHARLIE_URL=http://general-charlie:8012

# --- GENERAL DELTA — The Operator (Qwen3-30B Local) :8013 -------------------
# No API key — runs locally on Ollama
GENERAL_DELTA_URL=http://general-delta:8013

# Delta's Trading API Keys (PAPER TRADING by default!)
PAPER_TRADING_ONLY=true
ALPACA_API_KEY=REPLACE_ME
ALPACA_SECRET_KEY=REPLACE_ME
BINANCE_API_KEY=REPLACE_ME
BINANCE_SECRET_KEY=REPLACE_ME

# --- SHARED BRAIN: Ollama (Local Inference) ----------------------------------
OLLAMA_BASE_URL=http://ollama:11434
# Models to pull on first boot:
#   ollama pull qwen3:30b-a3b
#   ollama pull deepseek-r1:14b
#   ollama pull nomic-embed-text

# --- SHARED BRAIN: Qdrant (Vector Memory) -----------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- SHARED BRAIN: Redis (Pub/Sub + Cache) -----------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- SHARED BRAIN: MinIO (Data Lake) ----------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=cipher
MINIO_SECRET_KEY=cipherops2026
MINIO_BUCKET=cipher-data-lake

# --- KVM8 VPS (for SSH deployment) ------------------------------------------
KVM8_HOST=REPLACE_ME
KVM8_USER=root
KVM8_SSH_KEY_PATH=~/.ssh/cipher_kvm8_ed25519

# --- PORTS -------------------------------------------------------------------
ARBITER_PORT=8000
BRIDGE_PORT=8001
# Alpha :8010 | Bravo :8011 | Charlie :8012 | Delta :8013
